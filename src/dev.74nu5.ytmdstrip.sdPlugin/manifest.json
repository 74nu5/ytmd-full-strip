{
  "SDKVersion": 3,
  "UUID": "dev.74nu5.ytmdstrip",
  "Author": "74nu5",
  "Name": "Full Strip for YTMD",
  "Category": "Full Strip for YTMD",
  "CategoryIcon": "icons/strip",
  "Description": "Shows the current YouTube Music Desktop track across the full width of the Stream Deck + touch strip: album art, title, artist and progress. Requires YouTube Music Desktop with its companion server enabled.",
  "Version": "1.0.1.0",
  "Icon": "icons/plugin",
  "URL": "https://github.com/74nu5/ytmd-full-strip",
  "CodePath": "action.html",
  "Software": {
    "MinimumVersion": "6.9"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Actions": [
    {
      "Icon": "icons/strip",
      "Name": "Full Strip",
      "UUID": "dev.74nu5.ytmdstrip.slice",
      "PropertyInspectorPath": "pi.html",
      "Controllers": [
        "Encoder"
      ],
      "Encoder": {
        "layout": "layouts/fullbleed.json",
        "TriggerDescription": {
          "Rotate": "Volume",
          "Push": "Play / Pause",
          "Touch": "Play / Pause"
        }
      },
      "States": [
        {
          "Image": "icons/strip"
        }
      ],
      "SupportedInMultiActions": false,
      "Tooltip": "One slice of the 800x100 strip. Place it on each dial."
    }
  ]
}